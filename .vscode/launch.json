{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Setup Wizard",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/setup_dynatrace_application.js",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Generate Sessions (Default)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/rum_session_generator.js",
      "args": ["config/business_config.json"],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Generate Sessions (Harvard Pilgrim)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/rum_session_generator.js",
      "args": ["examples/harvard_pilgrim_config.json"],
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current File",
      "skipFiles": ["<node_internals>/**"],
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ]
}
